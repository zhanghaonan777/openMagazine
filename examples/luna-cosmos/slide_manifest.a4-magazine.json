          "role": "text",
          "z_index": 10,
          "text": "She steps from the module into a silence that has waited four billion years for the sound of a paw.",
          "component": "Lead",
          "typography": {
            "family_chain": ["Source Serif 4", "Georgia"],
            "size_pt": 13,
            "weight": 400,
            "style": "italic",
