{% set spread_idx = sc.idx %}
{% set img = images_root ~ '/spread-' ~ '{:02d}'.format(spread_idx) ~ '/back_coda.png' %}

<section class="spread back-cover" data-spread-idx="{{ spread_idx }}">
  <div style="position: relative; width: 100%; height: 277mm; overflow: hidden;">
    <img class="slot" src="{{ img }}"
         style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;">
    {% if sc.quote and sc.quote[language] %}
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;
                background: linear-gradient(180deg, rgba(0,0,0,0.0) 50%, rgba(0,0,0,0.55) 100%);
                z-index: 1;"></div>
    <blockquote class="pull-quote"
                style="position: absolute; left: 16mm; right: 16mm; bottom: 30mm; z-index: 2;
                       color: var(--color-bg-paper);
                       text-align: center; font-size: 22pt;">
      {{ sc.quote[language] }}
    </blockquote>
    {% endif %}
  </div>
</section>
